local function toggleButton(name,icon)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1,-20,0,55)
	container.BackgroundColor3 = Color3.fromRGB(30,10,50)
	container.Parent = content

	Instance.new("UICorner",container).CornerRadius = UDim.new(0,12)

	local iconLabel = Instance.new("TextLabel")
	iconLabel.Size = UDim2.new(0,32,0,32)
	iconLabel.Position = UDim2.new(0,10,0.5,-16)
	iconLabel.Text = icon
	iconLabel.TextScaled = true
	iconLabel.Font = Enum.Font.GothamBold
	iconLabel.BackgroundColor3 = Color3.fromRGB(120,40,200)
	iconLabel.TextColor3 = Color3.new(1,1,1)
	iconLabel.Parent = container
	Instance.new("UICorner",iconLabel)

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size = UDim2.new(1,-110,0,20)
	nameLabel.Position = UDim2.new(0,50,0.5,-10)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = name
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextColor3 = Color3.fromRGB(230,200,255)
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Parent = container

	local status = Instance.new("TextLabel")
	status.Size = UDim2.new(0,80,0,20)
	status.Position = UDim2.new(1,-90,0.5,-10)
	status.BackgroundTransparency = 1
	status.Text = "Inactive"
	status.TextColor3 = Color3.fromRGB(150,120,200)
	status.Font = Enum.Font.Gotham
	status.Parent = container

	local button = Instance.new("TextButton")
	button.Size = UDim2.new(1,0,1,0)
	button.BackgroundTransparency = 1
	button.Text = ""
	button.Parent = container

	local on=false
	button.MouseButton1Click:Connect(function()
		on=not on
		status.Text= on and "Active" or "Inactive"
	end)
end

